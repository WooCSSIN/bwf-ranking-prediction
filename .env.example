# BWF Ranking Prediction — Environment Variables
# Copy this file to .env and fill in your values

# ── Paths ────────────────────────────────────────────────────────────────────
# (Optional) Override default paths
# DATA_RAW_DIR=data/raw
# MODELS_DIR=models

# ── Forecast Settings ────────────────────────────────────────────────────────
FORECAST_MONTHS=120
BASE_YEAR=2024
TARGET_YEAR=2035

# ── Model Hyperparameters ────────────────────────────────────────────────────
N_ESTIMATORS=200
LEARNING_RATE=0.05
MAX_DEPTH=5

# ── API Settings (Phase 3) ───────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── MLflow Settings (Phase 2) ────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_PREFIX=bwf

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
